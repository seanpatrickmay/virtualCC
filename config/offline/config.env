CO_MAX_RETRIES=3
CO_BACKOFF_INITIAL=30
CO_BACKOFF_MAX=300
CO_MAX_BUDGET_USD=5.00
CO_MAX_RUNTIME=7200
CO_FALLBACK_MODEL=sonnet
CO_MODEL=
CO_PERMISSION_MODE=bypassPermissions
# NOTE: Leave CO_NOTIFY_URL empty if using claude-phone-notify (cron-based).
# Setting this to the same ntfy topic as NTFY_TOPIC in ~/.config/claude-phone/config
# would cause duplicate notifications (one from claude-offline, one from the cron job).
# Only set this if you want claude-offline to send its own notifications independently.
CO_NOTIFY_URL=
CO_NOTIFY_ON_SUCCESS=true
CO_NOTIFY_ON_FAILURE=true
CO_LOG_DIR="$HOME/.local/log/claude-offline"
CO_EXTRA_FLAGS=
