if [[ -f "$PHONE_CONFIG" ]]; then
    _phone_ip=$(grep '^VCC_IP=' "$PHONE_CONFIG" | cut -d= -f2)
    _phone_port=$(grep '^HTTP_PORT=' "$PHONE_CONFIG" | cut -d= -f2)
    _phone_token=$(grep '^AUTH_TOKEN=' "$PHONE_CONFIG" | cut -d= -f2)
    if [[ -n "$_phone_ip" && -n "$_phone_port" && -n "$_phone_token" ]]; then
        echo ""
        echo "Phone dashboard: http://${_phone_ip}:${_phone_port}/${_phone_token}/"
