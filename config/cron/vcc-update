#!/bin/bash
# Self-update: pull latest virtualCC repo and re-apply configs.
# Runs as dev cron (daily). Safe to run manually too.
# Reads config/manifest.txt for file installation.
# Uses jq to merge JSON configs (preserves user overrides).

LOG_DIR="$HOME/.local/log/cron"
SENTINEL="$LOG_DIR/vcc-update-failed"
mkdir -p "$LOG_DIR"

VCCDIR="$HOME/.local/share/virtualCC"

{
    echo "=== VCC self-update: $(date) ==="

    if [ ! -d "$VCCDIR/.git" ]; then
        echo "SKIP: virtualCC repo not found at $VCCDIR"
        echo "=== Done: $(date) ==="
        exit 0
    fi

    cd "$VCCDIR" || exit 1

    # Pull latest (ff-only to avoid conflicts)
    if ! git pull --ff-only; then
        echo "WARNING: git pull --ff-only failed. Manual intervention needed."
        touch "$SENTINEL"
        echo "=== Done: $(date) ==="
        exit 1
    fi

    echo "Applying updated configs..."

    # Read manifest and install files
    while IFS= read -r line; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        local_src=$(echo "$line" | awk '{print $1}')
        local_dest=$(echo "$line" | awk '{print $2}')
        local_mode=$(echo "$line" | awk '{print $3}')
        local_dest="${local_dest/#\~/$HOME}"

        if [ ! -f "$VCCDIR/$local_src" ]; then
            echo "WARNING: $local_src not found in repo, skipping"
            continue
        fi

        mkdir -p "$(dirname "$local_dest")"

        case "$local_mode" in
            json-merge)
                # Merge repo defaults with user's existing config (user wins)
                if [ -f "$local_dest" ] && command -v jq &>/dev/null; then
                    if jq -s '.[0] * .[1]' "$VCCDIR/$local_src" "$local_dest" > "$local_dest.tmp" 2>/dev/null; then
                        mv "$local_dest.tmp" "$local_dest"
                    else
                        rm -f "$local_dest.tmp"
                        cp "$VCCDIR/$local_src" "$local_dest"
                    fi
                else
                    cp "$VCCDIR/$local_src" "$local_dest"
                fi
                ;;
            bootstrap-only)
                # Only install if file doesn't exist (never overwrite user changes)
                [ -f "$local_dest" ] || cp "$VCCDIR/$local_src" "$local_dest"
                ;;
            +x)
                # Atomic write for executables (prevents self-overwrite mid-execution)
                cp "$VCCDIR/$local_src" "$local_dest.tmp" && mv "$local_dest.tmp" "$local_dest"
                chmod +x "$local_dest"
                ;;
            *)
                cp "$VCCDIR/$local_src" "$local_dest.tmp" && mv "$local_dest.tmp" "$local_dest"
                ;;
        esac
    done < "$VCCDIR/config/manifest.txt"

    rm -f "$SENTINEL"
    echo "Configs applied."
    echo "=== Done: $(date) ==="
} >> "$LOG_DIR/vcc-update.log" 2>&1
